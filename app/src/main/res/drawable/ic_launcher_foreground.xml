<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      A Safe Zone é um círculo de 66dp de diâmetro no centro (54,54).
      Desenhamos os elementos centralizados para evitar cortes em qualquer launcher.
    -->
    <group
        android:translateX="54"
        android:translateY="54">

        <!-- Lua Crescente (Branca) -->
        <!-- Raio de 30dp (Diâmetro 60dp, dentro dos 66dp da Safe Zone) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,-30
                              A30,30 0 1,1 0,30
                              A24,26 0 0,0 0,-30 Z" />

        <!-- Coração (Rosa) -->
        <!-- Posicionado proporcionalmente dentro da curva da lua -->
        <path
            android:fillColor="#FF6FAE"
            android:pathData="M0,-5
                              C0,-9 6,-9 6,-5
                              C6,-1 0,5 0,5
                              C0,5 -6,-1 -6,-5
                              C-6,-9 0,-9 0,-5 Z"
            android:translateX="10"
            android:translateY="0" />
    </group>
</vector>